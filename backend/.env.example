# App
APP_ENV=development
APP_PORT=8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=soc_ticketing
DB_SSL_MODE=disable

# JWT
JWT_SECRET=change-me-super-secret
JWT_ISSUER=dashboard-soc
JWT_AUD=dashboard-soc
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=168h

# Seed (optional) - SOC_MANAGER bootstrap
# You can also pass these as flags to: go run ./cmd/seed
SEED_SOC_MANAGER_FULL_NAME=SOC Manager
SEED_SOC_MANAGER_USERNAME=soc_manager
SEED_SOC_MANAGER_PASSWORD=change-me-strong-password

# API KEY
WEBHOOK_API_KEY=sixxxsevennnnn

# External ticket analysis API
ANALYZE_API_URL=http://localhost:8000/analyze/go
ANALYZE_MODELS_URL=http://localhost:8000/api/v1/models
ANALYZE_API_KEY=
ANALYZE_API_TIMEOUT=60s