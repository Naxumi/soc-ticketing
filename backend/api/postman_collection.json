    {
      "name": "Webhook",
      "item": [
        {
          "name": "Wazuh Raw Logs Grouping Test (Run 3x)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{webhookApiKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/webhook/wazuh/raw-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "webhook", "wazuh", "raw-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"id\": \"{{groupEventId}}\",\n    \"customer\": \"{{groupCustomer}}\",\n    \"source_ip\": \"{{groupSourceIp}}\",\n    \"received_at\": \"{{groupNowIso}}\",\n    \"raw_log\": {\n      \"alert\": {\n        \"rule\": {\n          \"id\": \"{{groupRuleId}}\",\n          \"level\": 8\n        },\n        \"data\": {\n          \"src_ip\": \"{{groupSourceIp}}\",\n          \"timestamp\": \"{{groupNowIso}}\",\n          \"url\": \"/search.php\"\n        }\n      },\n      \"llm_metadata\": {\n        \"category\": \"Web Attack\",\n        \"attack_type\": \"SQL Injection\",\n        \"severity\": \"high\",\n        \"severity_level\": 8,\n        \"indicators\": {\n          \"source_ip\": \"{{groupSourceIp}}\"\n        }\n      }\n    }\n  }\n]"
            },
            "description": "Gunakan Collection Runner dengan Iterations = 3 agar request ini dieksekusi 3 kali beruntun."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const nowIso = new Date().toISOString();",
                  "const runId = pm.collectionVariables.get('groupRunId') || String(Date.now());",
                  "if (!pm.collectionVariables.get('groupRunId')) pm.collectionVariables.set('groupRunId', runId);",
                  "const iter = (pm.info && typeof pm.info.iteration === 'number') ? pm.info.iteration + 1 : 1;",
                  "const eventId = `evt-group-${runId}-${iter}-${Date.now()}`;",
                  "pm.collectionVariables.set('groupNowIso', nowIso);",
                  "pm.collectionVariables.set('groupEventId', eventId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "let res = null;",
                  "try { res = pm.response.json(); } catch (e) {}",
                  "if (res && res.success && res.data) {",
                  "  if (Array.isArray(res.data.created_ticket_ids) && res.data.created_ticket_ids.length > 0) {",
                  "    pm.collectionVariables.set('ticketId', res.data.created_ticket_ids[0]);",
                  "  }",
                  "}",
                  "",
                  "console.log('grouping test response', res);"
                ]
              }
            }
          ]
        },
        {
          "name": "Wazuh Raw Logs Batch Ingest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
